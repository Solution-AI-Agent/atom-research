---
import Research from '../../layouts/Research.astro';

const navLinks = [
  { href: '../', label: '상세 비교표' },
  { href: '../summary', label: 'Executive Summary' },
];

const SVC = [
  { id:'px', name:'Perplexity', color:'var(--blue)', bg:'var(--blue-bg)',
    base: 200,
    perTask: { simple: 0.15, medium: 1.50, heavy: 15.00 },
    overageFactor: 1,
    scores: { cost:3, quality:9, autonomy:10, breadth:8, privacy:5, enterprise:6 },
    summary: '리서치 정확도 최고. 19개 모델 자동 선택. 단, 크레딧 소진 빠르고 헤비유저 $500~$1,500+/월. 클라우드 전용으로 데스크톱/로컬 접근 불가.',
    risks: [
      '1작업에 1K~21K 크레딧 — 복잡 작업 시 월 할당 1~2건만에 소진',
      '추가 크레딧 캡 $200~$2,000 — 예산 초과 위험',
      '클라우드 샌드박스 전용 — 로컬 파일 접근 불가, 민감 데이터 제한'
    ],
    oks: ['신규 가입 시 35,000 크레딧 보너스 (첫 달 넉넉)', '작업별 크레딧 소모 투명하게 표시'] },
  { id:'cl', name:'Claude', color:'var(--amber)', bg:'var(--amber-bg)',
    base: 20,
    perTask: { simple: 0, medium: 0, heavy: 0 },
    overageFactor: 0,
    maxBase: { simple:20, medium:100, heavy:200 },
    scores: { cost:9, quality:9, autonomy:7, breadth:8, privacy:8, enterprise:9 },
    summary: 'SWE-bench 72.7% (업계 최고). $20 정액제로 Code+Cowork+데스크톱+모바일 통합. 로컬 우선 실행으로 프라이버시 우수. 윈도우 리셋으로 지속 사용 가능.',
    risks: [
      'Pro ~44K 토큰/5hr — 복잡 작업 1건에 윈도우 전체 소진 가능',
      '99.4%가 컨텍스트 재읽기 토큰 — /clear 미사용 시 낭비 심각',
      'Max 20x($200)도 Opus 4.6 연속 사용 시 부족할 수 있음'
    ],
    oks: ['시간 리셋으로 하루 종일 사용 가능', 'Opus가 Sonnet 대비 48~76% 토큰 절약'] },
  { id:'oa', name:'OpenAI', color:'var(--green)', bg:'var(--green-bg)',
    base: 20,
    perTask: { simple: 0, medium: 0, heavy: 0 },
    overageFactor: 0,
    maxBase: { simple:20, medium:20, heavy:200 },
    entBase: 60,
    entCredits: {
      codexLocal: { '5.3': 5, '5.4': 7, 'mini': 1 },
      codexCloud: { '5.3': 25, '5.4': 34 },
      codeReview: { '5.3': 25, '5.4': 34 },
      agent: 30, deepResearch: 50, imageGen: 6, voice: 5,
      gpt53: 0, gpt54thinking: 10, gpt54pro: 50
    },
    scores: { cost:7, quality:7, autonomy:6, breadth:10, privacy:5, enterprise:9 },
    summary: '생태계 최대. Codex+Sora+ImageGen+Voice 통합. Enterprise: GPT 5.3 무제한 + 크레딧 풀, SOC2/SCIM/EKM/HIPAA. 단, 150석 최소 연 $108K+.',
    risks: [
      'Enterprise ~$60/석 + 크레딧 풀 — 150석 최소 (연 $108K+)',
      'Codex Cloud 작업 25~34cr — 크레딧 풀 소진 속도 주의',
      '에이전트 30cr/msg, 심층 리서치 50cr/작업 — 고급 기능 크레딧 소모 큼',
      'Plus 소진 시 mini 모델 자동 전환 — 품질 급락'
    ],
    oks: ['GPT 5.3 Instant 무제한 (크레딧 소모 없음)', 'Codex Local ~5cr (5.3) — 저렴한 로컬 작업', 'mini 모델 ~1cr — 단순 작업 최저 비용'] },
  { id:'oc', name:'OpenClaw', color:'var(--red)', bg:'var(--red-bg)',
    base: 0,
    perTask: { simple: 0.05, medium: 0.30, heavy: 2.00 },
    overageFactor: 1,
    scores: { cost:6, quality:6, autonomy:5, breadth:7, privacy:10, enterprise:3 },
    summary: '완전한 데이터 통제. 제로 텔레메트리. 13,700+ Skills 생태계. 기업 기능 부재, 운영 인력 필요. 대량 사용 시 API 비용 $300+.',
    risks: [
      '대량 사용 시 API 비용 $100~$300+/월 — "무료"가 아닐 수 있음',
      '비용 예측 어려움 — 모델/작업에 따라 10~100배 차이',
      'SSO/감사 로그 등 기업 기능 직접 구축 필요',
      '보안 책임 전적으로 자체 — 사고 시 벤더 지원 없음'
    ],
    oks: ['소량 사용 시 $0.45~$6/월 가능', '모델 라우팅으로 60~80% 비용 절감 가능'] }
];

const DIMS = [
  { key:'cost', label:'비용 효율' },
  { key:'quality', label:'작업 품질' },
  { key:'autonomy', label:'자율성' },
  { key:'breadth', label:'기능 범위' },
  { key:'privacy', label:'프라이버시' },
  { key:'enterprise', label:'기업 기능' },
];
---
<Research
  title="TCO 분석 &<br>서비스 평가"
  label="Insights"
  sub="사용량에 따른 연간 비용과 서비스별 강점/약점/숨겨진 비용을 분석합니다."
  meta="2026년 3월 27일 기준 · 실측 데이터 기반"
  description="AI Agent TCO 분석 및 서비스 평가"
  navLinks={navLinks}
>
  <!-- TCO Simulator -->
  <div class="sec">
    <div class="sec-label">TCO Simulator</div>
    <div class="sec-title">사용량별 연간 비용</div>
    <div class="sec-desc">슬라이더로 월간 작업량을 조정하면 서비스별 연간 총비용이 계산됩니다.</div>

    <div class="sim-controls">
      <div class="sim-group">
        <div class="sim-label">월간 에이전트 작업 수</div>
        <div style="display:flex;align-items:center;gap:12px">
          <input type="range" class="sim-slider" id="taskSlider" min="5" max="200" value="50">
          <span class="sim-val" id="taskVal">50</span><span style="font-size:12px;color:var(--dim)">건/월</span>
        </div>
      </div>
      <div class="sim-group">
        <div class="sim-label">작업 복잡도</div>
        <div class="sim-pills" id="complexPills">
          <button class="sim-pill" data-complex="simple">단순</button>
          <button class="sim-pill active" data-complex="medium">보통</button>
          <button class="sim-pill" data-complex="heavy">복잡</button>
        </div>
      </div>
    </div>

    <div class="tco-grid" id="tcoGrid"></div>

    <!-- Enterprise Credit Reference -->
    <div style="margin-top:24px;border:1px solid var(--border2);border-radius:var(--r);overflow:hidden;background:var(--card)">
      <div style="padding:16px 18px;border-bottom:1px solid var(--border);font-size:14px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:8px">
        <div class="avg avg-sm" style="background:var(--green)">OA</div>
        OpenAI Enterprise 크레딧 소모 기준 (실제 데이터)
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:var(--border2)">
        <div style="background:var(--card);padding:16px">
          <div style="font-size:11px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px">모델</div>
          <div style="font-size:13px;color:var(--mid);line-height:2">
            <div style="display:flex;justify-content:space-between"><span>GPT 5.3 Instant</span><strong style="color:var(--green)">무제한</strong></div>
            <div style="display:flex;justify-content:space-between"><span>GPT-5.4 Thinking</span><strong>10 cr</strong></div>
            <div style="display:flex;justify-content:space-between"><span>GPT-5.4 Pro</span><strong>50 cr</strong></div>
          </div>
        </div>
        <div style="background:var(--card);padding:16px">
          <div style="font-size:11px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px">기능</div>
          <div style="font-size:13px;color:var(--mid);line-height:2">
            <div style="display:flex;justify-content:space-between"><span>에이전트</span><strong>30 cr/msg</strong></div>
            <div style="display:flex;justify-content:space-between"><span>심층 리서치</span><strong>50 cr/건</strong></div>
            <div style="display:flex;justify-content:space-between"><span>ImageGen</span><strong>6 cr/msg</strong></div>
            <div style="display:flex;justify-content:space-between"><span>음성</span><strong>5 cr/분</strong></div>
          </div>
        </div>
        <div style="background:var(--card);padding:16px">
          <div style="font-size:11px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px">Codex</div>
          <div style="font-size:13px;color:var(--mid);line-height:2">
            <div style="display:flex;justify-content:space-between"><span>Local (5.3)</span><strong>~5 cr</strong></div>
            <div style="display:flex;justify-content:space-between"><span>Local (5.4)</span><strong>~7 cr</strong></div>
            <div style="display:flex;justify-content:space-between"><span>Cloud (5.3)</span><strong>~25 cr</strong></div>
            <div style="display:flex;justify-content:space-between"><span>Cloud (5.4)</span><strong>~34 cr</strong></div>
            <div style="display:flex;justify-content:space-between"><span>Local (mini)</span><strong style="color:var(--green)">~1 cr</strong></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Radar Scores -->
  <div class="sec">
    <div class="sec-label">Service Evaluation</div>
    <div class="sec-title">서비스 강점/약점 평가</div>
    <div class="sec-desc">6개 축으로 평가. 10점 만점, 실측 데이터와 전문가 리뷰 기반.</div>
    <div class="radar-grid">
      {SVC.map(s => {
        const sc = s.scores;
        const vals = Object.values(sc);
        const avg = (vals.reduce((a, b) => a + b, 0) / DIMS.length).toFixed(1);
        return (
          <div class="radar-card">
            <div class="radar-head"><div class="avg" style={`background:${s.color}`}>{s.id.toUpperCase().slice(0,2)}</div><div class="radar-name">{s.name}</div></div>
            <div class="radar-scores">
              {DIMS.map(d => {
                const score = sc[d.key as keyof typeof sc];
                return (
                  <div class="radar-row">
                    <span class="radar-label">{d.label}</span>
                    <div class="radar-bar-wrap"><div class="radar-bar" style={`width:${score*10}%;background:${s.color}`}></div></div>
                    <span class="radar-val">{score}</span>
                  </div>
                );
              })}
            </div>
            <div style={`margin-top:10px;text-align:right;font-size:18px;font-weight:800;color:${s.color}`}>{avg}<span style="font-size:11px;color:var(--dim)">/10</span></div>
            <div class="radar-summary">{s.summary}</div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Hidden Costs & Risks -->
  <div class="sec">
    <div class="sec-label">Hidden Costs & Risks</div>
    <div class="sec-title">숨겨진 비용과 리스크</div>
    <div class="sec-desc">공식 가격표에 드러나지 않는 실질 비용 요소.</div>
    <div class="risk-grid">
      {SVC.map(s => (
        <div class="risk-card">
          <div class="risk-head"><div class="avg avg-sm" style={`background:${s.color}`}>{s.id.toUpperCase().slice(0,2)}</div><div class="risk-title">{s.name}</div></div>
          <div class="risk-items">
            {s.risks.map(r => <div class="risk-item">{r}</div>)}
            {s.oks.map(r => <div class="risk-item ok">{r}</div>)}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Data Sources -->
  <div class="sec">
    <div class="sec-label">Data Sources</div>
    <div class="sec-title">TCO 산출 기초 데이터 및 출처</div>
    <div class="sec-desc">본 분석에 사용된 비용 추정치의 근거입니다. 실측 데이터와 공식 문서를 기반으로 합니다.</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
      <div style="border:1px solid var(--border2);border-radius:var(--r);padding:22px;background:var(--card)">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
          <div class="avg avg-sm" style="background:var(--blue)">Px</div>
          <div style="font-size:15px;font-weight:800">Perplexity Computer</div>
        </div>
        <div style="font-size:13px;color:var(--mid);line-height:1.8">
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>기본 가격:</strong> $200/월 (Max 구독) -- 공식 가격표</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>월 크레딧:</strong> 10,000cr -- Perplexity Help Center</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>단순 작업:</strong> 31~37cr -- Substack 실측 (karozieminski)</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>보통 작업:</strong> 44~61cr -- Substack 실측</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>복잡 작업:</strong> 1K~21Kcr -- Reddit 사용자 리포트 (28만줄 코드 스캔)</div>
          <div style="padding:6px 0"><strong>헤비유저 월비용:</strong> $500~$1,500+ -- FindSkill.ai, TrySliq 분석</div>
        </div>
      </div>
      <div style="border:1px solid var(--border2);border-radius:var(--r);padding:22px;background:var(--card)">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
          <div class="avg avg-sm" style="background:var(--amber)">Cl</div>
          <div style="font-size:15px;font-weight:800">Claude Code / Cowork</div>
        </div>
        <div style="font-size:13px;color:var(--mid);line-height:1.8">
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Pro 가격:</strong> $20/월 -- 공식 가격표</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Pro 토큰:</strong> ~44K/5hr -- Faros.ai, Claude Help Center</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Max 5x:</strong> ~88K/5hr -- Faros.ai 분석</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Max 20x:</strong> ~220K/5hr -- SSDNodes 분석</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>세션 비용:</strong> 중앙값 $0.41 / 최대 $6.30 -- dev.to 38세션 분석</div>
          <div style="padding:6px 0"><strong>일 평균:</strong> ~$6 (90% 사용자 &lt;$12) -- Anthropic 공식 데이터</div>
        </div>
      </div>
      <div style="border:1px solid var(--border2);border-radius:var(--r);padding:22px;background:var(--card)">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
          <div class="avg avg-sm" style="background:var(--green)">OA</div>
          <div style="font-size:15px;font-weight:800">OpenAI Codex</div>
        </div>
        <div style="font-size:13px;color:var(--mid);line-height:1.8">
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Plus 가격:</strong> $20/월, Pro $200/월, Enterprise ~$60/석/월 -- 공식</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>GPT 5.3 Instant:</strong> 무제한 (크레딧 소모 없음) -- Enterprise 실제 데이터</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>GPT-5.4 Thinking:</strong> 10cr/msg, <strong>Pro:</strong> 50cr/msg -- Enterprise 실제 데이터</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>에이전트:</strong> 30cr/msg, <strong>심층 리서치:</strong> 50cr/작업 -- Enterprise 실제 데이터</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Codex Local:</strong> ~5cr (5.3) / ~7cr (5.4) / ~1cr (mini) -- Enterprise 실제 데이터</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>Codex Cloud:</strong> ~25cr (5.3) / ~34cr (5.4) -- Enterprise 실제 데이터</div>
          <div style="padding:6px 0"><strong>Code Review:</strong> ~25cr (5.3) / ~34cr (5.4) per PR -- Enterprise 실제 데이터</div>
        </div>
      </div>
      <div style="border:1px solid var(--border2);border-radius:var(--r);padding:22px;background:var(--card)">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
          <div class="avg avg-sm" style="background:var(--red)">OC</div>
          <div style="font-size:15px;font-weight:800">OpenClaw</div>
        </div>
        <div style="font-size:13px;color:var(--mid);line-height:1.8">
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>소프트웨어:</strong> 무료 (오픈소스) -- 공식</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>작업당 토큰:</strong> 80K~150K (3~8 LLM 콜) -- GLBgpt 분석</div>
          <div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>소량 사용:</strong> $0.45~$6/월 -- yu-wenhao 배포 가이드</div>
          <div style="padding:6px 0"><strong>대량 사용:</strong> $100~$300+/월 -- GLBgpt 가격 가이드</div>
        </div>
      </div>
    </div>
    <div style="margin-top:16px;padding:16px;border-radius:var(--r);background:var(--border);font-size:13px;color:var(--mid);line-height:1.7">
      <strong style="color:var(--text)">산출 방식:</strong> TCO 시뮬레이터의 "단순/보통/복잡" 복잡도별 작업당 비용은 위 실측 데이터의 범위에서 대표값을 추출한 것입니다. 정액제(Claude, OpenAI)는 복잡도에 따라 추천 플랜이 달라지며, 종량제(Perplexity, OpenClaw)는 작업 수에 비례하여 계산됩니다. 실제 비용은 작업 유형, 모델 선택, 컨텍스트 크기에 따라 크게 달라질 수 있습니다.
    </div>
  </div>
</Research>

<style>
  .sec-desc{font-size:14px;color:var(--dim);margin-bottom:20px;line-height:1.7}

  /* TCO Simulator */
  .sim-controls{display:flex;gap:16px;align-items:flex-end;margin-bottom:24px;flex-wrap:wrap}
  .sim-group{display:flex;flex-direction:column;gap:4px}
  .sim-label{font-size:12px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1px}
  .sim-slider{-webkit-appearance:none;width:220px;height:6px;background:var(--border2);border-radius:3px;outline:none}
  .sim-slider::-webkit-slider-thumb{-webkit-appearance:none;width:24px;height:24px;border-radius:50%;background:var(--text);cursor:pointer}
  .sim-val{font-size:24px;font-weight:800;letter-spacing:-0.5px;min-width:60px}
  .sim-pills{display:flex;gap:6px}
  .sim-pill{padding:8px 16px;border-radius:8px;font-size:13px;font-weight:700;border:1px solid var(--border2);background:var(--card);color:var(--dim);cursor:pointer;font-family:inherit}
  .sim-pill.active{background:var(--text);color:var(--bg);border-color:var(--text)}

  /* TCO Results */
  .tco-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
  .tco-card{background:var(--card);padding:28px 24px;position:relative;border:1px solid var(--border2);border-radius:var(--r);overflow:hidden;transition:all 0.25s}
  .tco-card:hover{border-color:var(--dim)}
  .tco-accent{position:absolute;top:0;left:0;right:0;height:3px}
  .tco-head{display:flex;align-items:center;gap:10px;margin-bottom:16px}
  .tco-name{font-size:16px;font-weight:800}
  .tco-monthly{font-size:13px;color:var(--dim);margin-bottom:6px;line-height:1.5}
  .tco-annual{font-size:32px;font-weight:800;letter-spacing:-1.5px}
  .tco-annual span{font-size:14px;font-weight:500;color:var(--dim)}
  .tco-divider{height:1px;background:var(--border);margin:16px 0}
  .tco-bar-wrap{height:8px;background:var(--border);border-radius:4px;overflow:hidden}
  .tco-bar{height:100%;border-radius:4px;transition:width 0.5s ease}
  .tco-breakdown{margin-top:10px;font-size:13px;color:var(--mid);line-height:1.5}
  .tco-warn{margin-top:12px;padding:10px 14px;border-radius:8px;font-size:12px;font-weight:600;line-height:1.5}

  /* Radar / Score */
  .radar-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border2);border-radius:var(--r);overflow:hidden}
  .radar-card{background:var(--card);padding:24px 18px}
  .radar-head{display:flex;align-items:center;gap:8px;margin-bottom:16px}
  .radar-name{font-size:16px;font-weight:800}
  .radar-scores{display:flex;flex-direction:column;gap:10px}
  .radar-row{display:flex;align-items:center;gap:10px}
  .radar-label{font-size:13px;color:var(--dim);width:80px;flex-shrink:0}
  .radar-bar-wrap{flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden}
  .radar-bar{height:100%;border-radius:4px;transition:width 0.5s ease}
  .radar-val{font-size:13px;font-weight:800;width:28px;text-align:right}
  .radar-summary{margin-top:16px;padding-top:14px;border-top:1px solid var(--border);font-size:13px;color:var(--mid);line-height:1.7}

  /* Hidden costs */
  .risk-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:20px}
  .risk-card{border:1px solid var(--border2);border-radius:var(--r);padding:22px;background:var(--card)}
  .risk-head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
  .risk-title{font-size:15px;font-weight:800}
  .risk-items{display:flex;flex-direction:column;gap:8px}
  .risk-item{font-size:13px;color:var(--mid);line-height:1.6;padding-left:14px;position:relative}
  .risk-item::before{content:'';position:absolute;left:0;top:7px;width:6px;height:6px;border-radius:50%;background:var(--red)}
  .risk-item.ok::before{background:var(--green)}

  /* Mobile */
  @media(max-width:768px){
    .tco-grid,.radar-grid{grid-template-columns:1fr}
    .risk-grid{grid-template-columns:1fr}
    .sim-controls{flex-direction:column;align-items:flex-start}
    .sim-slider{width:100%}
  }
</style>

<script define:vars={{ SVC }}>
  let complexity = 'medium';

  function updateTCO() {
    const tasks = parseInt(document.getElementById('taskSlider').value);
    document.getElementById('taskVal').textContent = tasks;

    const results = SVC.map(s => {
      let monthly, annual, breakdown;
      if (s.perTask[complexity] === 0) {
        const base = s.maxBase ? s.maxBase[complexity] : s.base;
        monthly = base;
        annual = base * 12;
        breakdown = `$${base}/월 정액`;
      } else {
        const taskCost = s.perTask[complexity] * tasks;
        monthly = s.base + taskCost;
        annual = monthly * 12;
        breakdown = s.base > 0
          ? `구독 $${s.base} + 작업 $${taskCost.toFixed(0)}/월`
          : `API $${taskCost.toFixed(0)}/월`;
      }
      return { ...s, monthly, annual, breakdown };
    });

    const maxAnnual = Math.max(...results.map(r => r.annual));

    let html = '';
    results.forEach(r => {
      const pct = maxAnnual > 0 ? (r.annual / maxAnnual * 100) : 0;
      let warn = '';
      if (r.id === 'px' && tasks > 30 && complexity !== 'simple') {
        warn = `<div class="tco-warn" style="background:var(--red-bg);color:var(--red)">월 크레딧 초과 가능 — 추가 과금 발생</div>`;
      }
      if (r.id === 'cl' && complexity === 'heavy') {
        warn = `<div class="tco-warn" style="background:var(--amber-bg);color:var(--amber)">Max 20x 추천 — Pro는 윈도우 부족</div>`;
      }
      if (r.id === 'oa' && tasks > 25 && complexity !== 'simple') {
        warn = `<div class="tco-warn" style="background:var(--green-bg);color:var(--green)">일 25건 초과 — Pro($200) 고려</div>`;
      }
      html += `
        <div class="tco-card">
          <div class="tco-accent" style="background:${r.color}"></div>
          <div class="tco-head"><div class="avg" style="background:${r.color}">${r.id.toUpperCase().slice(0,2)}</div><div class="tco-name">${r.name}</div></div>
          <div class="tco-monthly">${r.breakdown}</div>
          <div class="tco-annual" style="color:${r.color}">$${r.annual.toLocaleString()}<span>/년</span></div>
          <div class="tco-divider"></div>
          <div class="tco-bar-wrap"><div class="tco-bar" style="width:${pct}%;background:${r.color}"></div></div>
          <div class="tco-breakdown">월 $${r.monthly.toLocaleString()}</div>
          ${warn}
        </div>`;
    });
    document.getElementById('tcoGrid').innerHTML = html;
  }

  document.getElementById('taskSlider').addEventListener('input', updateTCO);

  document.querySelectorAll('.sim-pill').forEach(pill => {
    pill.addEventListener('click', function() {
      complexity = this.dataset.complex;
      document.querySelectorAll('.sim-pill').forEach(p => p.classList.remove('active'));
      this.classList.add('active');
      updateTCO();
    });
  });

  updateTCO();
</script>

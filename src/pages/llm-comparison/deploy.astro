---
import Research from '../../layouts/Research.astro';

const navLinks = [
  { href: './', label: '메인' },
  { href: 'specs', label: '모델 스펙' },
  { href: 'usecase', label: '용도별 비교' },
  { href: 'summary', label: '요약' },
  { href: 'insights', label: '인사이트' },
];
---
<Research
  title="LLM 배포 옵션<br>비교"
  label="LLM Deployment Comparison"
  sub="OpenAI, Anthropic, Google, Meta, Mistral, DeepSeek — 주요 LLM 모델의 Cloud API, 온프레미스, 오픈소스, 파인튜닝, 데이터 프라이버시 종합 비교"
  meta="2026년 3월 기준"
  description="OpenAI, Anthropic, Google, Meta, Mistral, DeepSeek — 주요 LLM 모델의 클라우드 API, 온프레미스, 오픈소스, 파인튜닝, 데이터 프라이버시 비교"
  navLinks={navLinks}
>
  <!-- Section 1: Providers Overview -->
  <div class="sec">
    <div class="sec-label">Providers</div>
    <div class="sec-title">프로바이더 개요</div>
    <div class="hero-grid" style="grid-template-columns:repeat(3,1fr)">
      <div class="hero"><div class="avg" style="background:var(--green)">OAI</div><div class="hero-name">OpenAI</div><div class="hero-billing">GPT-4o &middot; GPT-4.1 &middot; o3 &middot; o4-mini</div><div class="hero-tag tag-prop">Proprietary</div></div>
      <div class="hero"><div class="avg" style="background:var(--amber)">ANT</div><div class="hero-name">Anthropic</div><div class="hero-billing">Opus 4.6 &middot; Sonnet 4.6 &middot; Haiku 4.5</div><div class="hero-tag tag-prop">Proprietary</div></div>
      <div class="hero"><div class="avg" style="background:var(--blue)">GOO</div><div class="hero-name">Google</div><div class="hero-billing">Gemini 2.5 Pro &middot; Gemini 2.5 Flash</div><div class="hero-tag tag-prop">Proprietary</div></div>
    </div>
    <div class="hero-grid" style="grid-template-columns:repeat(3,1fr)">
      <div class="hero"><div class="avg" style="background:#1877F2">META</div><div class="hero-name">Meta</div><div class="hero-billing">Llama 4 Maverick &middot; Llama 4 Scout</div><div class="hero-tag tag-semi">Semi-Open (Llama License)</div></div>
      <div class="hero"><div class="avg" style="background:var(--purple)">MIS</div><div class="hero-name">Mistral</div><div class="hero-billing">Mistral Large 3 &middot; Mistral Medium 3</div><div class="hero-tag tag-open">Open (Apache 2.0)</div></div>
      <div class="hero"><div class="avg" style="background:var(--red)">DS</div><div class="hero-name">DeepSeek</div><div class="hero-billing">DeepSeek-V3 &middot; DeepSeek-R1</div><div class="hero-tag tag-open">Open (MIT)</div></div>
    </div>
  </div>

  <!-- Section 2: API Pricing -->
  <div class="sec">
    <div class="sec-label">API Pricing</div>
    <div class="sec-title">API 가격 비교 ($/1M tokens)</div>
    <div class="bench">
      <table>
        <thead><tr><th>모델</th><th>Input $/1M</th><th>Output $/1M</th><th>Context</th><th>유형</th><th>Batch 할인</th></tr></thead>
        <tbody>
          <tr class="cat-row"><td colspan="6">OpenAI</td></tr>
          <tr><td>GPT-4o</td><td>$2.50</td><td>$10.00</td><td>128K</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr><td>GPT-4.1</td><td>$2.00</td><td>$8.00</td><td>1M</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr><td>o3</td><td>$10.00</td><td>$40.00</td><td>200K</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr><td>o4-mini</td><td>$1.10</td><td>$4.40</td><td>200K</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr class="cat-row"><td colspan="6">Anthropic</td></tr>
          <tr><td>Claude Opus 4.6</td><td>$5.00</td><td>$25.00</td><td>1M</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr><td>Claude Sonnet 4.6</td><td>$3.00</td><td>$15.00</td><td>1M</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr><td>Claude Haiku 4.5</td><td>$1.00</td><td>$5.00</td><td>200K</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr class="cat-row"><td colspan="6">Google</td></tr>
          <tr><td>Gemini 2.5 Pro</td><td>$1.25</td><td>$10.00</td><td>1M</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr><td>Gemini 2.5 Flash</td><td>$0.30</td><td>$2.50</td><td>1M</td><td><span class="tag-prop">Proprietary</span></td><td>50%</td></tr>
          <tr class="cat-row"><td colspan="6">Meta (Llama 4)</td></tr>
          <tr><td>Llama 4 Maverick</td><td colspan="2" style="font-size:12px;color:var(--dim)">오픈 웨이트 — 셀프호스팅 or 클라우드 종량제</td><td>1M</td><td><span class="tag-semi">Llama License</span></td><td>-</td></tr>
          <tr><td>Llama 4 Scout</td><td colspan="2" style="font-size:12px;color:var(--dim)">오픈 웨이트 — 셀프호스팅 or 클라우드 종량제</td><td>10M</td><td><span class="tag-semi">Llama License</span></td><td>-</td></tr>
          <tr class="cat-row"><td colspan="6">Mistral</td></tr>
          <tr><td>Mistral Large 3</td><td>$0.50</td><td>$1.50</td><td>256K</td><td><span class="tag-open">Apache 2.0</span></td><td>-</td></tr>
          <tr><td>Mistral Medium 3</td><td>$0.40</td><td>$2.00</td><td>128K</td><td><span class="tag-open">Apache 2.0</span></td><td>-</td></tr>
          <tr class="cat-row"><td colspan="6">DeepSeek</td></tr>
          <tr><td>DeepSeek-V3</td><td>$0.28</td><td>$0.42</td><td>128K</td><td><span class="tag-open">MIT</span></td><td>-</td></tr>
          <tr><td>DeepSeek-R1</td><td>$0.55</td><td>$2.19</td><td>128K</td><td><span class="tag-open">MIT</span></td><td>-</td></tr>
        </tbody>
      </table>
      <div class="bench-cards">
        <div class="bench-card"><div class="bench-card-title">OpenAI</div><div class="bench-card-row"><span class="bench-card-label">GPT-4o</span><span>$2.50 / $10.00</span></div><div class="bench-card-row"><span class="bench-card-label">GPT-4.1</span><span>$2.00 / $8.00</span></div><div class="bench-card-row"><span class="bench-card-label">o3</span><span>$10.00 / $40.00</span></div><div class="bench-card-row"><span class="bench-card-label">o4-mini</span><span>$1.10 / $4.40</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Anthropic</div><div class="bench-card-row"><span class="bench-card-label">Opus 4.6</span><span>$5.00 / $25.00</span></div><div class="bench-card-row"><span class="bench-card-label">Sonnet 4.6</span><span>$3.00 / $15.00</span></div><div class="bench-card-row"><span class="bench-card-label">Haiku 4.5</span><span>$1.00 / $5.00</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Google</div><div class="bench-card-row"><span class="bench-card-label">Gemini 2.5 Pro</span><span>$1.25 / $10.00</span></div><div class="bench-card-row"><span class="bench-card-label">Gemini 2.5 Flash</span><span>$0.30 / $2.50</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Meta / Mistral / DeepSeek</div><div class="bench-card-row"><span class="bench-card-label">Mistral Large 3</span><span>$0.50 / $1.50</span></div><div class="bench-card-row"><span class="bench-card-label">Mistral Medium 3</span><span>$0.40 / $2.00</span></div><div class="bench-card-row"><span class="bench-card-label">DeepSeek-V3</span><span>$0.28 / $0.42</span></div><div class="bench-card-row"><span class="bench-card-label">DeepSeek-R1</span><span>$0.55 / $2.19</span></div></div>
      </div>
      <div class="bench-note"><strong>Input / Output 기준, 2026년 공식 가격표 기준.</strong> Batch API 할인은 OpenAI/Anthropic/Google 50%. 오픈 웨이트 모델은 셀프호스팅 시 GPU 비용만 발생.</div>
    </div>
  </div>

  <!-- Section 3: Output Token Price Bar Chart -->
  <div class="sec">
    <div class="sec-label">Cost Benchmark</div>
    <div class="sec-title">Output 가격 비교</div>
    <div class="bar-chart">
      <div class="bar-row"><div class="bar-label">DeepSeek-V3</div><div class="bar-track"><div class="bar-fill" style="width:2%;background:var(--red)"></div></div><div class="bar-val">$0.42</div></div>
      <div class="bar-row"><div class="bar-label">Mistral Large 3</div><div class="bar-track"><div class="bar-fill" style="width:4%;background:var(--purple)"></div></div><div class="bar-val">$1.50</div></div>
      <div class="bar-row"><div class="bar-label">Mistral Medium 3</div><div class="bar-track"><div class="bar-fill" style="width:5%;background:var(--purple)"></div></div><div class="bar-val">$2.00</div></div>
      <div class="bar-row"><div class="bar-label">DeepSeek-R1</div><div class="bar-track"><div class="bar-fill" style="width:6%;background:var(--red)"></div></div><div class="bar-val">$2.19</div></div>
      <div class="bar-row"><div class="bar-label">Gemini 2.5 Flash</div><div class="bar-track"><div class="bar-fill" style="width:7%;background:var(--blue)"></div></div><div class="bar-val">$2.50</div></div>
      <div class="bar-row"><div class="bar-label">o4-mini</div><div class="bar-track"><div class="bar-fill" style="width:11%;background:var(--green)"></div></div><div class="bar-val">$4.40</div></div>
      <div class="bar-row"><div class="bar-label">Claude Haiku 4.5</div><div class="bar-track"><div class="bar-fill" style="width:13%;background:var(--amber)"></div></div><div class="bar-val">$5.00</div></div>
      <div class="bar-row"><div class="bar-label">GPT-4.1</div><div class="bar-track"><div class="bar-fill" style="width:20%;background:var(--green)"></div></div><div class="bar-val">$8.00</div></div>
      <div class="bar-row"><div class="bar-label">GPT-4o</div><div class="bar-track"><div class="bar-fill" style="width:25%;background:var(--green)"></div></div><div class="bar-val">$10.00</div></div>
      <div class="bar-row"><div class="bar-label">Gemini 2.5 Pro</div><div class="bar-track"><div class="bar-fill" style="width:25%;background:var(--blue)"></div></div><div class="bar-val">$10.00</div></div>
      <div class="bar-row"><div class="bar-label">Claude Sonnet 4.6</div><div class="bar-track"><div class="bar-fill" style="width:38%;background:var(--amber)"></div></div><div class="bar-val">$15.00</div></div>
      <div class="bar-row"><div class="bar-label">Claude Opus 4.6</div><div class="bar-track"><div class="bar-fill" style="width:63%;background:var(--amber)"></div></div><div class="bar-val">$25.00</div></div>
      <div class="bar-row"><div class="bar-label">o3</div><div class="bar-track"><div class="bar-fill" style="width:100%;background:var(--green)"></div></div><div class="bar-val">$40.00</div></div>
    </div>
  </div>

  <!-- Section 4: Cloud Platform Integration -->
  <div class="sec">
    <div class="sec-label">Cloud Platform Integration</div>
    <div class="sec-title">클라우드 플랫폼 가용성</div>
    <div class="bench">
      <table>
        <thead><tr><th>모델</th><th>자체 API</th><th>AWS Bedrock</th><th>Azure AI</th><th>Google Vertex AI</th></tr></thead>
        <tbody>
          <tr class="cat-row"><td colspan="5">OpenAI</td></tr>
          <tr><td>GPT-4o</td><td class="good">O</td><td class="na">X (GPT-OSS만)</td><td class="good">O (Azure OpenAI)</td><td class="na">X</td></tr>
          <tr><td>GPT-4.1</td><td class="good">O</td><td class="na">X (GPT-OSS만)</td><td class="good">O (Azure OpenAI)</td><td class="na">X</td></tr>
          <tr><td>o3</td><td class="good">O</td><td class="na">X</td><td class="good">O (Azure OpenAI)</td><td class="na">X</td></tr>
          <tr><td>o4-mini</td><td class="good">O</td><td class="na">X</td><td class="good">O (Azure OpenAI)</td><td class="na">X</td></tr>
          <tr class="cat-row"><td colspan="5">Anthropic</td></tr>
          <tr><td>Claude Opus 4.6</td><td class="good">O</td><td class="good">O (Global+Regional)</td><td class="na">X</td><td class="good">O</td></tr>
          <tr><td>Claude Sonnet 4.6</td><td class="good">O</td><td class="good">O (Global+Regional)</td><td class="na">X</td><td class="good">O</td></tr>
          <tr><td>Claude Haiku 4.5</td><td class="good">O</td><td class="good">O (Global+Regional)</td><td class="na">X</td><td class="good">O</td></tr>
          <tr class="cat-row"><td colspan="5">Google</td></tr>
          <tr><td>Gemini 2.5 Pro</td><td class="good">O (Gemini API)</td><td class="na">X</td><td class="na">X</td><td class="good">O (GA)</td></tr>
          <tr><td>Gemini 2.5 Flash</td><td class="good">O (Gemini API)</td><td class="na">X</td><td class="na">X</td><td class="good">O (GA)</td></tr>
          <tr class="cat-row"><td colspan="5">Meta</td></tr>
          <tr><td>Llama 4 Maverick</td><td class="na">X (셀프호스팅)</td><td class="good">O (서버리스)</td><td class="good">O (AI Foundry)</td><td class="good">O (MaaS)</td></tr>
          <tr><td>Llama 4 Scout</td><td class="na">X (셀프호스팅)</td><td class="good">O (서버리스)</td><td class="good">O (AI Foundry)</td><td class="good">O (MaaS)</td></tr>
          <tr class="cat-row"><td colspan="5">Mistral</td></tr>
          <tr><td>Mistral Large 3</td><td class="good">O (La Plateforme)</td><td class="na">미확인</td><td class="good">O (AI Foundry)</td><td class="good">O</td></tr>
          <tr><td>Mistral Medium 3</td><td class="good">O (La Plateforme)</td><td class="good">O (SageMaker)</td><td class="good">O (AI Foundry)</td><td class="good">O</td></tr>
          <tr class="cat-row"><td colspan="5">DeepSeek</td></tr>
          <tr><td>DeepSeek-V3</td><td class="good">O</td><td class="na">X (셀프호스팅)</td><td class="na">X (셀프호스팅)</td><td class="na">X (셀프호스팅)</td></tr>
          <tr><td>DeepSeek-R1</td><td class="good">O</td><td class="good">O (Marketplace)</td><td class="good">O (AI Foundry)</td><td class="na">X (셀프호스팅)</td></tr>
        </tbody>
      </table>
      <div class="bench-cards">
        <div class="bench-card"><div class="bench-card-title">OpenAI</div><div class="bench-card-row"><span class="bench-card-label">자체 API</span><span class="good">O</span></div><div class="bench-card-row"><span class="bench-card-label">AWS Bedrock</span><span class="na">X (GPT-OSS만)</span></div><div class="bench-card-row"><span class="bench-card-label">Azure AI</span><span class="good">O (Azure OpenAI)</span></div><div class="bench-card-row"><span class="bench-card-label">Vertex AI</span><span class="na">X</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Anthropic</div><div class="bench-card-row"><span class="bench-card-label">자체 API</span><span class="good">O</span></div><div class="bench-card-row"><span class="bench-card-label">AWS Bedrock</span><span class="good">O (Global+Regional)</span></div><div class="bench-card-row"><span class="bench-card-label">Azure AI</span><span class="na">X</span></div><div class="bench-card-row"><span class="bench-card-label">Vertex AI</span><span class="good">O</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Google</div><div class="bench-card-row"><span class="bench-card-label">자체 API</span><span class="good">O (Gemini API)</span></div><div class="bench-card-row"><span class="bench-card-label">AWS Bedrock</span><span class="na">X</span></div><div class="bench-card-row"><span class="bench-card-label">Azure AI</span><span class="na">X</span></div><div class="bench-card-row"><span class="bench-card-label">Vertex AI</span><span class="good">O (GA)</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Meta (Llama 4)</div><div class="bench-card-row"><span class="bench-card-label">자체 API</span><span class="na">X (셀프호스팅)</span></div><div class="bench-card-row"><span class="bench-card-label">AWS Bedrock</span><span class="good">O (서버리스)</span></div><div class="bench-card-row"><span class="bench-card-label">Azure AI</span><span class="good">O (AI Foundry)</span></div><div class="bench-card-row"><span class="bench-card-label">Vertex AI</span><span class="good">O (MaaS)</span></div></div>
        <div class="bench-card"><div class="bench-card-title">Mistral</div><div class="bench-card-row"><span class="bench-card-label">자체 API</span><span class="good">O (La Plateforme)</span></div><div class="bench-card-row"><span class="bench-card-label">AWS Bedrock</span><span class="na">미확인 / O (SageMaker)</span></div><div class="bench-card-row"><span class="bench-card-label">Azure AI</span><span class="good">O (AI Foundry)</span></div><div class="bench-card-row"><span class="bench-card-label">Vertex AI</span><span class="good">O</span></div></div>
        <div class="bench-card"><div class="bench-card-title">DeepSeek</div><div class="bench-card-row"><span class="bench-card-label">자체 API</span><span class="good">O</span></div><div class="bench-card-row"><span class="bench-card-label">AWS Bedrock</span><span class="na">X / O (R1 Marketplace)</span></div><div class="bench-card-row"><span class="bench-card-label">Azure AI</span><span class="na">X / O (R1 AI Foundry)</span></div><div class="bench-card-row"><span class="bench-card-label">Vertex AI</span><span class="na">X (셀프호스팅)</span></div></div>
      </div>
    </div>
  </div>

  <!-- Section 5: Open Source & Self-Hosting -->
  <div class="sec">
    <div class="sec-label">Open Source &amp; Self-Hosting</div>
    <div class="sec-title">오픈소스 / 셀프호스팅</div>
    <div class="arch-grid">
      <div class="arch"><div class="arch-cat">Proprietary</div><div class="arch-title">셀프호스팅 불가</div><div class="arch-item"><div class="avg avg-xs" style="background:var(--green)">OA</div><strong>GPT-4o / 4.1 / o3</strong><span class="arch-env env-c">API 전용</span></div><div class="arch-item"><div class="avg avg-xs" style="background:var(--amber)">AN</div><strong>Claude 전모델</strong><span class="arch-env env-c">API 전용</span></div><div class="arch-item"><div class="avg avg-xs" style="background:var(--blue)">GO</div><strong>Gemini 2.5 Pro/Flash</strong><span class="arch-env env-c">API 전용</span></div></div>
      <div class="arch"><div class="arch-cat">Semi-Open</div><div class="arch-title">조건부 오픈</div><div class="arch-item"><div class="avg avg-xs" style="background:#1877F2">ME</div><strong>Llama 4 Scout</strong><span class="arch-env env-h">1x H100</span></div><div style="font-size:11px;color:var(--dim);padding:4px 0 8px 28px">~55GB VRAM (INT4) &middot; MAU 7억 초과 시 별도 계약</div><div class="arch-item"><div class="avg avg-xs" style="background:#1877F2">ME</div><strong>Llama 4 Maverick</strong><span class="arch-env env-h">4x H100</span></div><div style="font-size:11px;color:var(--dim);padding:4px 0 0 28px">~200GB VRAM (INT4) &middot; EU 제한 조항 존재</div></div>
      <div class="arch"><div class="arch-cat">Open Source</div><div class="arch-title">완전 오픈</div><div class="arch-item"><div class="avg avg-xs" style="background:var(--purple)">MI</div><strong>Mistral Large 3</strong><span class="arch-env env-l">Apache 2.0</span></div><div style="font-size:11px;color:var(--dim);padding:4px 0 8px 28px">8x H200 (FP8) &middot; 제한 없음</div><div class="arch-item"><div class="avg avg-xs" style="background:var(--red)">DS</div><strong>DeepSeek-V3</strong><span class="arch-env env-l">MIT</span></div><div style="font-size:11px;color:var(--dim);padding:4px 0 8px 28px">~380GB VRAM (FP8) &middot; 8x H100 권장</div><div class="arch-item"><div class="avg avg-xs" style="background:var(--red)">DS</div><strong>DeepSeek-R1</strong><span class="arch-env env-l">MIT</span></div><div style="font-size:11px;color:var(--dim);padding:4px 0 0 28px">~1.5TB VRAM (Full) &middot; Distill: 4~48GB</div></div>
    </div>
  </div>

  <!-- Section 6: Fine-Tuning -->
  <div class="sec">
    <div class="sec-label">Fine-Tuning</div>
    <div class="sec-title">파인튜닝 지원 현황</div>
    <div class="bench">
      <table>
        <thead><tr><th>모델</th><th>파인튜닝</th><th>방법</th><th>플랫폼</th><th>학습 비용</th><th>비고</th></tr></thead>
        <tbody>
          <tr class="cat-row"><td colspan="6">OpenAI</td></tr>
          <tr><td>GPT-4o</td><td class="good">O</td><td>LoRA (API)</td><td>OpenAI API, Azure</td><td>미확인</td><td>JSONL 데이터셋</td></tr>

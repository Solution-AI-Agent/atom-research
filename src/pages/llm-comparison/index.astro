---
import Research from '../../layouts/Research.astro';

const navLinks = [
  { href: 'specs', label: '모델 스펙' },
  { href: 'usecase', label: '용도별 비교' },
  { href: 'deploy', label: '배포 옵션' },
  { href: 'summary', label: '요약' },
  { href: 'insights', label: '인사이트' },
];
---
<Research
  title="LLM 모델 비교 분석"
  label="LLM Model Comparison"
  sub="2025년 주요 LLM 모델의 성능, 과금, 용도별 적합성, 배포 옵션 종합 비교"
  meta="2026년 3월 기준"
  description="2025년 주요 LLM 모델의 성능, 과금, 용도별 적합성, 배포 옵션 종합 비교"
  navLinks={navLinks}
>
  <!-- Section 1: Key Highlights -->
  <div class="sec">
    <div class="sec-label">Key Highlights</div>
    <div class="sec-title">핵심 하이라이트</div>
    <div class="hero-grid">
      <div class="hero">
        <div class="avg" style="background:var(--blue)">Co</div>
        <div class="hero-name">Claude Opus 4.6</div>
        <div class="hero-billing">Best Coding</div>
        <div class="hero-price" style="color:var(--blue)">80.8%</div>
        <div class="hero-note">SWE-bench Verified</div>
      </div>
      <div class="hero">
        <div class="avg" style="background:var(--green)">o4</div>
        <div class="hero-name">o4-mini</div>
        <div class="hero-billing">Best Reasoning</div>
        <div class="hero-price" style="color:var(--green)">92.7%</div>
        <div class="hero-note">AIME 2024</div>
      </div>
      <div class="hero">
        <div class="avg" style="background:var(--amber)">DS</div>
        <div class="hero-name">DeepSeek-V3</div>
        <div class="hero-billing">Best Value</div>
        <div class="hero-price" style="color:var(--amber)">$0.27<span>/$1.10</span></div>
        <div class="hero-note">per 1M tokens (in/out)</div>
      </div>
      <div class="hero">
        <div class="avg" style="background:var(--purple)">Ll</div>
        <div class="hero-name">Llama 4 Scout</div>
        <div class="hero-billing">Largest Context</div>
        <div class="hero-price" style="color:var(--purple)">10M</div>
        <div class="hero-note">tokens context window</div>
      </div>
    </div>
  </div>

  <!-- Section 2: Cost Comparison -->
  <div class="sec">
    <div class="sec-label">Cost Comparison</div>
    <div class="sec-title">비용 비교 ($/1M tokens, 1:1 비율)</div>
    <div class="bar-wrap">
      <div class="bar-row">
        <div class="bar-label">Llama 4 Scout (Groq)</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:1.5%;background:var(--green)"></div>
        </div>
        <div class="bar-val">$0.45</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">DeepSeek-V3</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:4.6%;background:var(--green)"></div>
        </div>
        <div class="bar-val">$1.37</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Mistral Large 3</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:6.7%;background:var(--green)"></div>
        </div>
        <div class="bar-val">$2.00</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Gemini 2.5 Flash</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:9.3%;background:var(--amber)"></div>
        </div>
        <div class="bar-val">$2.80</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">o4-mini</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:18.3%;background:var(--amber)"></div>
        </div>
        <div class="bar-val">$5.50</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Claude Haiku 4.5</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:20%;background:var(--amber)"></div>
        </div>
        <div class="bar-val">$6.00</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">GPT-4.1</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:33.3%;background:var(--blue)"></div>
        </div>
        <div class="bar-val">$10.00</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Gemini 2.5 Pro</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:37.5%;background:var(--blue)"></div>
        </div>
        <div class="bar-val">$11.25</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">GPT-4o</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:41.7%;background:var(--blue)"></div>
        </div>
        <div class="bar-val">$12.50</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Claude Sonnet 4.6</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:60%;background:var(--purple)"></div>
        </div>
        <div class="bar-val">$18.00</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Claude Opus 4.6</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:100%;background:var(--red)"></div>
        </div>
        <div class="bar-val">$30.00</div>
      </div>
    </div>
  </div>

  <!-- Section 3: Use-case Winners -->
  <div class="sec">
    <div class="sec-label">Use-case Winners</div>
    <div class="sec-title">용도별 추천 모델</div>
    <div class="bench">
      <table>
        <thead>
          <tr>
            <th>용도</th>
            <th>최고 성능</th>
            <th>가성비 추천</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Coding</td>
            <td><span class="bench-good">Claude Opus 4</span></td>
            <td>o4-mini</td>
          </tr>
          <tr>
            <td>Reasoning / Math</td>
            <td><span class="bench-good">o3 / o4-mini</span></td>
            <td>DeepSeek-R1</td>
          </tr>
          <tr>
            <td>Multilingual (KR)</td>
            <td><span class="bench-good">Claude Opus 4</span></td>
            <td>Llama 4 Maverick</td>
          </tr>
          <tr>
            <td>AI Agent</td>
            <td><span class="bench-good">Claude Opus 4</span></td>
            <td>Claude Haiku 4.5</td>
          </tr>
          <tr>
            <td>RAG / Long Context</td>
            <td><span class="bench-good">Gemini 2.5 Pro</span></td>
            <td>Gemini 2.5 Flash</td>
          </tr>
          <tr>
            <td>Vision / Multimodal</td>
            <td><span class="bench-good">Gemini 2.5 Pro</span></td>
            <td>Gemini 2.5 Flash</td>
          </tr>
          <tr>
            <td>Creative Writing</td>
            <td><span class="bench-good">Claude Opus 4</span></td>
            <td>GPT-4o</td>
          </tr>
        </tbody>
      </table>
      <div class="bench-cards">
        <div class="bench-card">
          <div class="bench-card-title">Coding</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">Claude Opus 4</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>o4-mini</span></div>
        </div>
        <div class="bench-card">
          <div class="bench-card-title">Reasoning / Math</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">o3 / o4-mini</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>DeepSeek-R1</span></div>
        </div>
        <div class="bench-card">
          <div class="bench-card-title">Multilingual (KR)</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">Claude Opus 4</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>Llama 4 Maverick</span></div>
        </div>
        <div class="bench-card">
          <div class="bench-card-title">AI Agent</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">Claude Opus 4</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>Claude Haiku 4.5</span></div>
        </div>
        <div class="bench-card">
          <div class="bench-card-title">RAG / Long Context</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">Gemini 2.5 Pro</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>Gemini 2.5 Flash</span></div>
        </div>
        <div class="bench-card">
          <div class="bench-card-title">Vision / Multimodal</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">Gemini 2.5 Pro</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>Gemini 2.5 Flash</span></div>
        </div>
        <div class="bench-card">
          <div class="bench-card-title">Creative Writing</div>
          <div class="bench-card-row"><span class="bench-card-label">최고 성능</span><span class="bench-good">Claude Opus 4</span></div>
          <div class="bench-card-row"><span class="bench-card-label">가성비 추천</span><span>GPT-4o</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 4: 2025 Key Trends -->
  <div class="sec">
    <div class="sec-label">2025 Key Trends</div>
    <div class="sec-title">2025년 주요 트렌드</div>
    <div class="trend-grid">
      <div class="trend-card">
        <div class="trend-num">Trend 01</div>
        <div class="trend-title">추론 모델 대중화</div>
        <div class="trend-desc">DeepSeek R1이 오픈소스 추론 모델을 촉발, OpenAI o-시리즈와 함께 전 개발사가 추종하며 추론 특화 모델이 표준으로 자리잡음</div>
      </div>
      <div class="trend-card">
        <div class="trend-num">Trend 02</div>
        <div class="trend-title">에이전트의 해</div>
        <div class="trend-desc">MCP 프로토콜 표준화, 에이전트 관련 문의 1,445% 급증. Claude Code, Codex 등 AI 코딩 에이전트가 실전 배치 시작</div>
      </div>
      <div class="trend-card">
        <div class="trend-num">Trend 03</div>
        <div class="trend-title">오픈소스 반격</div>
        <div class="trend-desc">오픈소스 모델이 시장 62.8% 점유. Llama 4, DeepSeek-V3, Qwen3 등이 프론티어 상용 모델과 직접 경쟁하는 수준에 도달</div>
      </div>
      <div class="trend-card">
        <div class="trend-num">Trend 04</div>
        <div class="trend-title">가격 붕괴</div>
        <div class="trend-desc">GPT-4 수준의 토큰 가격이 2년간 약 30배 하락. DeepSeek-V3의 $0.27/1M input이 새로운 가격 기준선을 형성</div>
      </div>
      <div class="trend-card wide">
        <div class="trend-num">Trend 05</div>
        <div class="trend-title">$500B 시대</div>
        <div class="trend-desc">OpenAI 기업가치 $300B 돌파, Stargate 프로젝트 $500B 투자 발표. AI 인프라 투자가 역대 최대 규모로 확대되며 산업 전체의 패러다임 전환 가속</div>
      </div>
    </div>
  </div>

  <!-- Section 5: Sub-page Navigation -->
  <div class="sec">
    <div class="sec-label">Deep Dive</div>
    <div class="sec-title">상세 분석 페이지</div>
    <div class="nav-grid">
      <a href="specs" class="nav-card">
        <div class="nav-card-title">모델 스펙 비교</div>
        <div class="nav-card-desc">컨텍스트 윈도우, 벤치마크 점수, 토큰 가격 등 주요 모델의 핵심 사양 비교표</div>
      </a>
      <a href="usecase" class="nav-card">
        <div class="nav-card-title">용도별 비교</div>
        <div class="nav-card-desc">코딩, 추론, 다국어, 에이전트, RAG, 비전 등 용도별 최적 모델 상세 분석</div>
      </a>
      <a href="deploy" class="nav-card">
        <div class="nav-card-title">배포 옵션</div>
        <div class="nav-card-desc">API 직접 호출, 라우터, 자체 호스팅, 엣지 배포 등 배포 방식별 비교와 추천</div>
      </a>
      <a href="summary" class="nav-card">
        <div class="nav-card-title">요약</div>
        <div class="nav-card-desc">전체 비교 결과의 핵심 요약과 시나리오별 최종 추천 모델 가이드</div>
      </a>
      <a href="insights" class="nav-card" style="grid-column:1/-1">
        <div class="nav-card-title">인사이트</div>
        <div class="nav-card-desc">2025년 LLM 시장 트렌드, 가격 변동 분석, 향후 전망 및 전략적 시사점</div>
      </a>
    </div>
  </div>

  <!-- Section 6: Data Sources -->
  <div class="sec">
    <div class="sec-label">Data Sources</div>
    <div class="sec-title">데이터 출처</div>
    <div class="bench-note">
      <strong>Chatbot Arena (LMSYS)</strong> &middot; SWE-bench Verified &middot; AIME 2024 &middot; MMLU-Pro &middot; GPQA Diamond<br>
      각 개발사 공식 가격 페이지 (Anthropic, OpenAI, Google, Meta, Mistral, DeepSeek)<br>
      Artificial Analysis &middot; Stanford HAI AI Index 2025 &middot; a16z AI Infrastructure Report
    </div>
  </div>
</Research>

<style>
  .trend-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .trend-card{background:var(--card);border-radius:var(--r);border:1px solid var(--border2);padding:24px;transition:all 0.25s}
  .trend-card:hover{border-color:var(--dim)}
  .trend-card.wide{grid-column:1/-1}
  .trend-num{font-size:11px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
  .trend-title{font-size:17px;font-weight:800;color:var(--text);margin-bottom:8px}
  .trend-desc{font-size:13px;color:var(--mid);line-height:1.7}

  .nav-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .nav-card{display:block;text-decoration:none;background:var(--card);border-radius:var(--r);border:1px solid var(--border2);padding:24px;transition:all 0.25s}
  .nav-card:hover{border-color:var(--dim)}
  .nav-card-title{font-size:17px;font-weight:800;color:var(--text);margin-bottom:6px}
  .nav-card-desc{font-size:13px;color:var(--mid);line-height:1.7}

  @media(max-width:768px){
    .trend-grid,.nav-grid{grid-template-columns:1fr}
    .trend-card.wide{grid-column:auto}
  }
</style>
